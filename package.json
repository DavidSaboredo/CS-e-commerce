{
  "name": "cs-venta-al-publico",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint js/**/*.js api/**/*.js tests/**/*.cjs",
    "test": "node --test tests/*.test.cjs",
    "format": "prettier --write \"js/{analytics,api,catalog,main,utils}.js\" \"api/orders.js\" \"tests/**/*.cjs\" \"package.json\" \".eslintrc.cjs\" \".prettierrc.json\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"js/{analytics,api,catalog,main,utils}.js\" \"api/orders.js\" \"tests/**/*.cjs\" \"package.json\" \".eslintrc.cjs\" \".prettierrc.json\" \".github/workflows/*.yml\""
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "prettier": "^3.3.3"
  }
}
